<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Storage Unit | Create User</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="main-header">
      <a href="/"
        ><img class="small-logo" src="/icons/storage-unit-icon.png" alt="storage unit logo"
      /></a>
      <nav class="main-nav">
        <a class="main-links" href="/folder">ALL FOLDERS</a>
        <a class="main-links" href="/file">ALL FILES</a>
        <%- include("../partials/loginLogout.ejs") %>
      </nav>
    </header>
    <main id="main-content" class="page-main">
      <form method="POST" action="/createUser">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-fields">
          <div class="create-user-title">
            <h1 class="create-user">Create New User</h1>
          </div>
          <div class="form-field">
            <label for="name">Name</label>
            <input
              type="text"
              name="name"
              id="name"
              placeholder="Name"
              value="<%= locals.formData?.name || '' %>"
              required
            />
          </div>
          <div class="form-field">
            <label for="email">Email Address</label>
            <input
              type="email"
              name="email"
              id="email"
              placeholder="Email Address"
              value="<%= locals.formData?.email || '' %>"
              required
            />
          </div>
          <div class="form-field">
            <label for="confirmEmail">Confirm Email Address</label>
            <input
              type="email"
              name="confirmEmail"
              id="confirmEmail"
              placeholder="Confirm Email Address"
              value="<%= locals.formData?.confirmEmail || '' %>"
              required
            />
          </div>
          <div class="form-field">
            <label for="password">Password</label>
            <input
              type="password"
              name="password"
              placeholder="Password"
              id="password"
              required
            />
          </div>
          <div class="form-field">
            <label for="confirmPassword">Confirm Password</label>
            <input
              type="password"
              name="confirmPassword"
              id="confirmPassword"
              placeholder="Confirm Password"
              required
            />
          </div>
          <p class="error" aria-live="polite"><%- include("../partials/passwordErrors.ejs") %></p>
          <button type="submit" class="create-button">Create User</button>
        </div>
      </form>
    </main>
    <footer>Thought Windows</footer>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Storage Unit | File Detail</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="main-header">
      <a href="/"
        ><img class="small-logo" src="/icons/storage-unit-icon.png" alt="storage unit logo"
      /></a>
      <nav class="main-nav">
        <a class="main-links" href="/folder">ALL FOLDERS</a>
        <a class="main-links" href="/file">ALL FILES</a>
        <%- include("../partials/loginLogout.ejs") %>
      </nav>
    </header>
    <main id="main-content">
      <h1>File Detail</h1>
      <h2><%= file.name %></h2>
      <dl>
        <dt>Size:</dt>
        <dd><%= formatFileSize(file.size) %></dd>
        <dt>Uploaded:</dt>
        <dd><%= formatDate(file.uploadtime) %></dd>
      </dl>
      <div class="file-button-div">
        <form action="<%= file.id %>/download" method="GET">
          <button class="file-button download-button" type="submit">
            Download File
          </button>
        </form>
        <form action="/file/<%= file.id %>?_method=DELETE" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="from" value="<%= from %>" />
          <button class="file-button delete-button" type="submit" onclick="return confirm('Delete this file? This cannot be undone.')">
            Delete File
          </button>
        </form>
      </div>
    </main>
    <footer>Thought Windows</footer>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Storage Unit | File Detail</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="main-header">
      <div class="logo-nav-form">
        <nav class="main-nav">
          <a class="main-links" href="/folder">All Folders</a>
          <a class="main-links" href="/file">All Files</a>
          <%- include("../partials/loginLogout.ejs") %>
        </nav>
      </div>
    </header>
    <h1>File Detail</h1>
    <h2><%= file.name %></h2>
    <dl>
      <dt>Size:</dt>
      <dd><%= formatFileSize(file.size) %></dd>
      <dt>Uploaded:</dt>
      <dd><%= file.uploadtime %></dd>
    </dl>
    <form action="<%= file.id %>/download" method="GET">
      <button type="submit">Download File</button>
    </form>
  </body>
</html>

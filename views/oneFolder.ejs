<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Storage Unit | Folder Detail</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="main-header">
      <div class="logo-nav-form">
        <nav class="main-nav">
          <a class="main-links" href="/folder">All Folders</a>
          <a class="main-links" href="/file">All Files</a>
          <%- include("../partials/loginLogout.ejs") %>
        </nav>
      </div>
    </header>
    <h1>Folder Detail</h1>
    <form action="/file/upload" enctype="multipart/form-data" method="post">
      <label for="upload">Upload File:</label>
      <input
        type="file"
        name="uploaded_file"
        id="uploaded_file"
        class="upload"
      />
      <input type="text" name="name" id="name" />
      <input type="hidden" name="<%= folder.id %>" />
      <button type="submit">Upload File</button>
    </form>
  </body>
</html>
